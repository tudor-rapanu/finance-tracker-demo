@inherits LayoutComponentBase
@using Microsoft.AspNetCore.Components.Routing
@inject NavigationManager Nav
@inject FinanceTracker.Web.Services.ApiClient Api

<div class="layout">
    <nav class="sidebar">
        <div class="logo">💰 FinTracker</div>
        <NavLink href="/" Match="NavLinkMatch.All">🏠 Dashboard</NavLink>
        <NavLink href="/transactions">💳 Transactions</NavLink>
        <NavLink href="/budgets">📊 Budgets</NavLink>
        @if (_isAdmin)
        {
            <NavLink href="/admin">🛡️ Admin</NavLink>
        }
        <div class="currency-box">
            <label for="preferredCurrency">Currency</label>
            <select id="preferredCurrency" @bind="_preferredCurrency" disabled="@_savingCurrency">
                <option>USD</option>
                <option>EUR</option>
                <option>GBP</option>
                <option>RON</option>
                <option>JPY</option>
                <option>CAD</option>
            </select>
            <button class="btn-save-currency" @onclick="SavePreferredCurrency" disabled="@_savingCurrency">
                @(_savingCurrency ? "Saving..." : "Save")
            </button>
            @if (!string.IsNullOrWhiteSpace(_currencyMessage))
            {
                <div class="currency-message">@_currencyMessage</div>
            }
        </div>
        <div style="margin-top:auto">
            <button @onclick="Logout">🚪 Logout</button>
        </div>
    </nav>
    <main class="content">
        @Body
    </main>
</div>

@code {
    private bool _isAdmin;
    private string _preferredCurrency = "USD";
    private bool _savingCurrency;
    private string? _currencyMessage;

    protected override async Task OnInitializedAsync()
    {
        _isAdmin = await Api.IsAdminAsync();
        _preferredCurrency = await Api.GetPreferredCurrencyAsync() ?? "USD";
    }

    private async Task SavePreferredCurrency()
    {
        _savingCurrency = true;
        _currencyMessage = null;

        var success = await Api.UpdatePreferredCurrencyAsync(_preferredCurrency);
        _currencyMessage = success
            ? "Currency updated."
            : "Could not update currency.";

        _savingCurrency = false;

        if (success)
            Nav.NavigateTo(Nav.Uri, forceLoad: true);
    }

    private async Task Logout()
    {
        await Api.LogoutAsync();
        Nav.NavigateTo("/login", forceLoad: true);
    }
}

<style>
    .layout { display: flex; min-height: 100vh; font-family: 'Segoe UI', sans-serif; }
    .sidebar { width: 220px; background: #1a1a2e; color: white; padding: 1.5rem 1rem; display: flex; flex-direction: column; gap: 0.5rem; }
    .logo { font-size: 1.4rem; font-weight: 700; margin-bottom: 1.5rem; }
    .sidebar a { color: #ccc; text-decoration: none; padding: 0.6rem 0.8rem; border-radius: 8px; display: block; }
    .sidebar a:hover, .sidebar a.active { background: #16213e; color: white; }
    .currency-box { margin-top: 1rem; padding: 0.6rem; border: 1px solid #2f3a57; border-radius: 8px; display: flex; flex-direction: column; gap: 0.4rem; }
    .currency-box label { font-size: 0.75rem; color: #b9c0d2; text-transform: uppercase; letter-spacing: 0.04em; }
    .currency-box select { width: 100%; padding: 0.45rem 0.55rem; border-radius: 6px; border: 1px solid #415278; background: #10182d; color: white; }
    .btn-save-currency { width: 100%; padding: 0.45rem; background: #3498db; color: white; border: none; border-radius: 6px; cursor: pointer; }
    .btn-save-currency:disabled { opacity: 0.7; cursor: not-allowed; }
    .currency-message { font-size: 0.72rem; color: #a9d6ff; }
    .sidebar button { width: 100%; padding: 0.6rem; background: #e74c3c; color: white; border: none; border-radius: 8px; cursor: pointer; }
    .content { flex: 1; padding: 2rem; background: #f4f6f9; }
</style>
