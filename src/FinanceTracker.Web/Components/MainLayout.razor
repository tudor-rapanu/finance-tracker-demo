@inherits LayoutComponentBase
@using Microsoft.AspNetCore.Components.Routing
@inject NavigationManager Nav
@inject FinanceTracker.Web.Services.ApiClient Api

<div class="layout">
    <div class="mobile-topbar">
        <button class="mobile-menu-button" @onclick="ToggleSidebar" aria-controls="sidebarNav" aria-expanded="@_sidebarOpen">
            @(_sidebarOpen ? "Close" : "Menu")
        </button>
        <div class="mobile-topbar-brand">FinTracker</div>
    </div>

    <div class="mobile-backdrop @(_sidebarOpen ? "show" : string.Empty)" @onclick="CloseSidebar"></div>

    <nav id="sidebarNav" class="sidebar @(_sidebarOpen ? "open" : string.Empty)">
        <div class="sidebar-header">
            <div class="logo">💰 FinTracker</div>
            <button class="sidebar-close-button" @onclick="CloseSidebar" aria-label="Close menu">Close</button>
        </div>
        <NavLink href="/" Match="NavLinkMatch.All" @onclick="CloseSidebar">🏠 Dashboard</NavLink>
        <NavLink href="/transactions" @onclick="CloseSidebar">💳 Transactions</NavLink>
        <NavLink href="/budgets" @onclick="CloseSidebar">📊 Budgets</NavLink>
        @if (_isAdmin)
        {
            <NavLink href="/admin" @onclick="CloseSidebar">🛡️ Admin</NavLink>
        }
        <div class="currency-box">
            <label for="preferredCurrency">Currency</label>
            <select id="preferredCurrency" @bind="_preferredCurrency" disabled="@_savingCurrency">
                <option>USD</option>
                <option>EUR</option>
                <option>GBP</option>
                <option>RON</option>
                <option>JPY</option>
                <option>CAD</option>
            </select>
            <button class="btn-save-currency" @onclick="SavePreferredCurrency" disabled="@_savingCurrency">
                @(_savingCurrency ? "Saving..." : "Save")
            </button>
            @if (!string.IsNullOrWhiteSpace(_currencyMessage))
            {
                <div class="status-block @(_currencyMessageIsSuccess ? "success" : "error")" role="status" aria-live="polite">
                    <ul>
                        @foreach (var line in SplitMessageLines(_currencyMessage))
                        {
                            <li>@line</li>
                        }
                    </ul>
                </div>
            }
        </div>
        <div class="logout-container">
            <button @onclick="Logout">🚪 Logout</button>
        </div>
    </nav>
    <main class="content">
        @Body
    </main>
</div>

@code {
    private bool _isAdmin;
    private string _preferredCurrency = "USD";
    private bool _savingCurrency;
    private string? _currencyMessage;
    private bool _currencyMessageIsSuccess;
    private bool _sidebarOpen;

    protected override async Task OnInitializedAsync()
    {
        _isAdmin = await Api.IsAdminAsync();
        _preferredCurrency = await Api.GetPreferredCurrencyAsync() ?? "USD";
    }

    private async Task SavePreferredCurrency()
    {
        _savingCurrency = true;
        _currencyMessage = null;
        _currencyMessageIsSuccess = false;

        var result = await Api.UpdatePreferredCurrencyAsync(_preferredCurrency);
        _currencyMessage = result.Success
            ? "Currency updated."
            : result.Error ?? "Could not update currency.";
        _currencyMessageIsSuccess = result.Success;

        _savingCurrency = false;

        if (result.Success)
            Nav.NavigateTo(Nav.Uri, forceLoad: true);
    }

    private void ToggleSidebar()
    {
        _sidebarOpen = !_sidebarOpen;
    }

    private void CloseSidebar()
    {
        _sidebarOpen = false;
    }

    private async Task Logout()
    {
        _sidebarOpen = false;
        await Api.LogoutAsync();
        Nav.NavigateTo("/login", forceLoad: true);
    }

    private static IEnumerable<string> SplitMessageLines(string? message)
    {
        if (string.IsNullOrWhiteSpace(message))
            return Array.Empty<string>();

        return message
            .Split(';', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries)
            .Where(s => !string.IsNullOrWhiteSpace(s));
    }
}
