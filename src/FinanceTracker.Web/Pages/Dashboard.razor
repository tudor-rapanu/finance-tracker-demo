@page "/"
@using Microsoft.AspNetCore.Components.Web
@inject FinanceTracker.Web.Services.ApiClient Api
@inject NavigationManager Nav
@inject PeriodStateService PeriodState

<PageTitle>Dashboard — FinTracker</PageTitle>

<div class="dashboard">
    <div class="page-header">
        <h1>Dashboard</h1>
        <div class="period-picker">
            <select @bind="SelectedMonth">
                @for (int m = 1; m <= 12; m++)
                {
                    <option value="@m">@(new DateTime(2000, m, 1).ToString("MMMM"))</option>
                }
            </select>
            <select @bind="SelectedYear">
                @for (int y = DateTime.Now.Year; y >= DateTime.Now.Year - 3; y--)
                {
                    <option value="@y">@y</option>
                }
            </select>
            <button @onclick="LoadData">Refresh</button>
        </div>
    </div>

    @if (_loading)
    {
        <p>Loading...</p>
    }
    else if (_dashboard is not null)
    {
        <div class="stat-cards">
            <div class="card income">
                <span class="label">Total Income</span>
                <span class="value">@_dashboard.TotalIncome.ToString("N2") @_dashboard.Currency</span>
            </div>
            <div class="card expense">
                <span class="label">Total Expenses</span>
                <span class="value">@_dashboard.TotalExpenses.ToString("N2") @_dashboard.Currency</span>
            </div>
            <div class="card net @(_dashboard.NetBalance >= 0 ? "positive" : "negative")">
                <span class="label">Net Balance</span>
                <span class="value">@_dashboard.NetBalance.ToString("N2") @_dashboard.Currency</span>
            </div>
        </div>

        <div class="chart-grid">
            <div class="section chart-section">
                <h2>Spending Breakdown</h2>
                <DonutChart Title="Spending Breakdown"
                            Segments="@GetSpendingChartSegments()"
                            CenterValue="@_dashboard.TotalExpenses.ToString("N0")"
                            CenterLabel="@_dashboard.Currency"
                            SelectedLabel="@_selectedSpendingLabel"
                            OnSelectionChanged="HandleSpendingSelectionChanged"
                            EmptyMessage="No expenses this period." />
            </div>

            <div class="section chart-section">
                <h2>Budget Overview</h2>
                <DonutChart Title="Budget Overview"
                            Segments="@GetBudgetChartSegments()"
                            CenterValue="@GetBudgetCenterValue()"
                            CenterLabel="@GetBudgetCenterLabel()"
                            SelectedLabel="@_selectedBudgetLabel"
                            OnSelectionChanged="HandleBudgetSelectionChanged"
                            EmptyMessage="No budgets set this period." />
            </div>
        </div>

        <div class="bottom-grid">
            <div class="section">
                <h2>Top Spending Categories</h2>
                @if (!string.IsNullOrWhiteSpace(_selectedSpendingLabel))
                {
                    <p class="filter-state">Showing only @_selectedSpendingLabel.</p>
                }

                @if (GetVisibleTopCategories().Any())
                {
                    @foreach (var cat in GetVisibleTopCategories())
                    {
                        <div class="category-row active">
                            <span>@((TransactionCategory)cat.Category)</span>
                            <div class="bar-wrap">
                                <div class="bar" style="width:@(cat.Percentage)%"></div>
                            </div>
                            <span>@cat.Amount.ToString("N2") @_dashboard.Currency</span>
                        </div>
                    }
                }
                else
                {
                    <p class="empty">No expenses this period.</p>
                }
            </div>

            <div class="section">
                <h2>Budget Status</h2>
                @if (!string.IsNullOrWhiteSpace(_selectedBudgetLabel))
                {
                    <p class="filter-state">Showing only @_selectedBudgetLabel budgets.</p>
                }

                @if (GetVisibleBudgets().Any())
                {
                    @foreach (var b in GetVisibleBudgets())
                    {
                        var pct = Math.Min(b.PercentageUsed, 100);
                        var color = pct >= 90 ? "#e74c3c" : pct >= 70 ? "#f39c12" : "#2ecc71";
                        <div class="budget-row active">
                            <div class="budget-header">
                                <span>@((TransactionCategory)b.Category)</span>
                                <span>@b.SpentAmount.ToString("N2") @b.Currency / @b.LimitAmount.ToString("N2") @b.Currency</span>
                            </div>
                            <div class="bar-wrap">
                                <div class="bar" style="width:@(pct)%; background:@color"></div>
                            </div>
                        </div>
                    }
                }
                else
                {
                    <p class="empty">No budgets set. <a href="/budgets">Add one →</a></p>
                }
            </div>
        </div>
    }
    else
    {
        <p>@_errorMessage <a href="/login">Please log in.</a></p>
    }
</div>

@code {
    private FinanceTracker.Contracts.DashboardDto? _dashboard;
    private bool _loading = true;
    private string _errorMessage = "Could not load dashboard.";
    private int SelectedMonth = DateTime.Now.Month;
    private int SelectedYear = DateTime.Now.Year;
    private string? _selectedSpendingLabel;
    private string? _selectedBudgetLabel;

    protected override async Task OnInitializedAsync()
    {
        if (!await Api.IsAuthenticatedAsync())
        {
            Nav.NavigateTo("/login");
            return;
        }

        await PeriodState.EnsureLoadedAsync();
        SelectedMonth = PeriodState.Month;
        SelectedYear = PeriodState.Year;
        await LoadData();
    }

    private async Task LoadData()
    {
        _loading = true;
        await PeriodState.SetAsync(SelectedMonth, SelectedYear);
        var result = await Api.GetDashboardAsync(SelectedMonth, SelectedYear);
        _selectedSpendingLabel = null;
        _selectedBudgetLabel = null;

        if (!result.Success)
        {
            _dashboard = null;
            _errorMessage = result.Error ?? "Could not load dashboard.";

            if (result.StatusCode == 401)
            {
                await Api.LogoutAsync();
                Nav.NavigateTo("/login", forceLoad: true);
                return;
            }
        }
        else
        {
            _dashboard = result.Data;
        }

        _loading = false;
    }

    private Task HandleSpendingSelectionChanged(string? label)
    {
        _selectedSpendingLabel = label;
        return Task.CompletedTask;
    }

    private Task HandleBudgetSelectionChanged(string? label)
    {
        _selectedBudgetLabel = label;
        return Task.CompletedTask;
    }

    private IReadOnlyList<FinanceTracker.Contracts.CategorySpendingDto> GetVisibleTopCategories()
    {
        if (_dashboard is null)
            return Array.Empty<FinanceTracker.Contracts.CategorySpendingDto>();

        if (string.IsNullOrWhiteSpace(_selectedSpendingLabel))
            return _dashboard.TopCategories.ToList();

        return _dashboard.TopCategories
            .Where(cat => ((TransactionCategory)cat.Category).ToString() == _selectedSpendingLabel)
            .ToList();
    }

    private IReadOnlyList<FinanceTracker.Contracts.BudgetDto> GetVisibleBudgets()
    {
        if (_dashboard is null)
            return Array.Empty<FinanceTracker.Contracts.BudgetDto>();

        if (string.IsNullOrWhiteSpace(_selectedBudgetLabel))
            return _dashboard.ActiveBudgets.ToList();

        return _selectedBudgetLabel switch
        {
            "Used" => _dashboard.ActiveBudgets.Where(budget => budget.SpentAmount > 0).ToList(),
            "Remaining" => _dashboard.ActiveBudgets.Where(budget => budget.RemainingAmount > 0).ToList(),
            "Over Budget" => _dashboard.ActiveBudgets.Where(budget => budget.RemainingAmount < 0 || budget.PercentageUsed > 100).ToList(),
            _ => _dashboard.ActiveBudgets.ToList()
        };
    }

    private IReadOnlyList<DonutChartSegment> GetSpendingChartSegments()
    {
        if (_dashboard is null || !_dashboard.TopCategories.Any())
            return Array.Empty<DonutChartSegment>();

        return _dashboard.TopCategories
            .OrderByDescending(c => c.Amount)
            .Select(c => new DonutChartSegment(
                ((TransactionCategory)c.Category).ToString(),
                c.Amount,
                $"{c.Amount:N2} {_dashboard.Currency}",
                GetCategoryColor(c.Category)))
            .ToList();
    }

    private IReadOnlyList<DonutChartSegment> GetBudgetChartSegments()
    {
        if (_dashboard is null || !_dashboard.ActiveBudgets.Any())
            return Array.Empty<DonutChartSegment>();

        var totalLimit = _dashboard.ActiveBudgets.Sum(b => b.LimitAmount);
        var totalSpent = _dashboard.ActiveBudgets.Sum(b => b.SpentAmount);
        var used = Math.Min(totalSpent, totalLimit);
        var remaining = Math.Max(totalLimit - totalSpent, 0m);
        var over = Math.Max(totalSpent - totalLimit, 0m);
        var segments = new List<DonutChartSegment>();

        if (used > 0)
            segments.Add(new DonutChartSegment("Used", used, $"{used:N2} {_dashboard.Currency}", "#3498db"));

        if (remaining > 0)
            segments.Add(new DonutChartSegment("Remaining", remaining, $"{remaining:N2} {_dashboard.Currency}", "#2ecc71"));

        if (over > 0)
            segments.Add(new DonutChartSegment("Over Budget", over, $"{over:N2} {_dashboard.Currency}", "#e74c3c"));

        return segments;
    }

    private string GetBudgetCenterValue()
    {
        if (_dashboard is null || !_dashboard.ActiveBudgets.Any())
            return "0%";

        var totalLimit = _dashboard.ActiveBudgets.Sum(b => b.LimitAmount);
        if (totalLimit <= 0)
            return "0%";

        var totalSpent = _dashboard.ActiveBudgets.Sum(b => b.SpentAmount);
        var usage = totalSpent / totalLimit * 100m;
        return $"{usage:0.#}%";
    }

    private string GetBudgetCenterLabel() => "used";

    private static string GetCategoryColor(int category) => category switch
    {
        10 => "#2563eb",
        11 => "#f59e0b",
        12 => "#10b981",
        13 => "#ef4444",
        14 => "#8b5cf6",
        15 => "#ec4899",
        16 => "#14b8a6",
        17 => "#f97316",
        18 => "#6366f1",
        _ => "#6b7280"
    };

    private enum TransactionCategory
    {
        Salary = 1, Freelance, Investment, Gift, OtherIncome,
        Housing = 10, Food, Transport, Healthcare, Entertainment, Shopping, Utilities, Education, Travel, OtherExpense
    }
}
