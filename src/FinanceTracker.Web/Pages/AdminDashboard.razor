@page "/admin"
@using FinanceTracker.Contracts
@inject FinanceTracker.Web.Services.ApiClient Api
@inject IJSRuntime JS
@inject NavigationManager Nav
@inject ToastService ToastService
@inject PeriodStateService PeriodState

<PageTitle>Admin Dashboard</PageTitle>

@if (_loading)
{
    <p>Loading...</p>
}
else if (!_isAdmin)
{
    <p>Access denied.</p>
}
else
{
    <div class="admin-page">
        <div class="page-header">
            <h1>Admin Dashboard</h1>
            <div class="period-picker">
                <select @bind="_selectedMonth">
                    @for (int m = 1; m <= 12; m++)
                    {
                        <option value="@m">@(new DateTime(2000, m, 1).ToString("MMMM"))</option>
                    }
                </select>
                <select @bind="_selectedYear">
                    @for (int y = DateTime.Now.Year; y >= DateTime.Now.Year - 3; y--)
                    {
                        <option value="@y">@y</option>
                    }
                </select>
                <button @onclick="LoadDataAsync">Refresh</button>
            </div>
        </div>

        @if (_stats is not null)
        {
            <div class="stats-grid">
                <div class="stat-card">
                    <div class="stat-label">Total Users</div>
                    <div class="stat-value">@_stats.TotalUsers</div>
                </div>
                <div class="stat-card">
                    <div class="stat-label">Total Transactions</div>
                    <div class="stat-value">@_stats.TotalTransactions</div>
                </div>
                <div class="stat-card income">
                    <div class="stat-label">System Income (USD)</div>
                    <div class="stat-value">$@_stats.TotalSystemIncome.ToString("N2")</div>
                </div>
                <div class="stat-card expense">
                    <div class="stat-label">System Expenses (USD)</div>
                    <div class="stat-value">$@_stats.TotalSystemExpenses.ToString("N2")</div>
                </div>
            </div>
        }

        <h2>All Users</h2>
        @if (_users.Count == 0)
        {
            <p>No users found.</p>
        }
        else
        {
            <div class="table-scroll">
                <table class="user-table">
                    <thead>
                        <tr>
                            <th>Name</th>
                            <th>Email</th>
                            <th>Currency</th>
                            <th>Joined</th>
                            <th>Roles</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var user in _users)
                        {
                            <tr>
                                <td>@user.FirstName @user.LastName</td>
                                <td>@user.Email</td>
                                <td>@user.PreferredCurrency</td>
                                <td>@user.CreatedAt.ToShortDateString()</td>
                                <td>@string.Join(", ", user.Roles)</td>
                                <td>
                                    @if (user.Roles.Contains("Admin"))
                                    {
                                        <button class="btn-action btn-action--danger" @onclick="() => ConfirmDemoteAdmin(user.Id)">Remove Admin</button>
                                    }
                                    else
                                    {
                                        <button class="btn-action btn-action--primary" @onclick="() => ConfirmPromoteAdmin(user.Id)">Make Admin</button>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }

        @if (!string.IsNullOrEmpty(_message))
        {
              <div class="status-block @(_messageIsSuccess ? "success" : "error")" role="status" aria-live="polite">
                  <ul>
                      @foreach (var line in SplitMessageLines(_message))
                      {
                          <li>@line</li>
                      }
                  </ul>
              </div>
        }
    </div>
}

<ConfirmDialog @ref="_confirmDialog" />

@code {
    private bool _loading = true;
    private bool _isAdmin;
    private AdminDashboardDto? _stats;
    private List<UserDto> _users = new();
    private string? _message;
    private bool _messageIsSuccess;
    private int _selectedMonth = DateTime.Now.Month;
    private int _selectedYear = DateTime.Now.Year;
    private ConfirmDialog? _confirmDialog;

    protected override async Task OnInitializedAsync()
    {
        _isAdmin = await Api.IsAdminAsync();
        if (!_isAdmin)
        {
            _loading = false;
            return;
        }

        await PeriodState.EnsureLoadedAsync();
        _selectedMonth = PeriodState.Month;
        _selectedYear = PeriodState.Year;
        await LoadDataAsync();
        _loading = false;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (_loading || !_isAdmin)
            return;

        await JS.InvokeVoidAsync("finTracker.updateTableScrollHints");
    }

    private async Task LoadDataAsync()
    {
        await PeriodState.SetAsync(_selectedMonth, _selectedYear);
        _stats = await Api.GetAdminStatsAsync(_selectedMonth, _selectedYear);
        _users = await Api.GetAdminUsersAsync();
    }

    private Task ConfirmPromoteAdmin(string userId) => ConfirmSetRole(userId, "Admin", true);
    private Task ConfirmDemoteAdmin(string userId) => ConfirmSetRole(userId, "Admin", false);

    private async Task ConfirmSetRole(string userId, string role, bool assign)
    {
        if (_confirmDialog is null) return;
        var user = _users.FirstOrDefault(u => u.Id == userId);
        var name = user is not null ? $"{user.FirstName} {user.LastName}" : "this user";
        var confirmed = await _confirmDialog.ShowAsync(
            assign ? $"Make {name} an Admin" : $"Remove Admin from {name}",
            assign
                ? $"{name} will gain full admin access to all users and system data."
                : $"{name} will lose admin access.",
            assign ? "Make Admin" : "Remove Admin",
            danger: !assign);
        if (!confirmed) return;
        await SetRole(userId, role, assign);
    }

    private async Task SetRole(string userId, string role, bool assign)
    {
        var result = await Api.SetUserRoleAsync(new SetUserRoleDto(userId, role, assign));
        if (result.Success)
        {
            _message = null;
            ToastService.Show($"Role '{role}' {(assign ? "assigned to" : "removed from")} user.");
        }
        else
        {
            _messageIsSuccess = false;
            _message = result.Error ?? "Failed to update role.";
        }
        await LoadDataAsync();
    }

      private static IEnumerable<string> SplitMessageLines(string? message)
      {
          if (string.IsNullOrWhiteSpace(message))
              return Array.Empty<string>();

          return message
              .Split(';', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries)
              .Where(s => !string.IsNullOrWhiteSpace(s));
      }
}
