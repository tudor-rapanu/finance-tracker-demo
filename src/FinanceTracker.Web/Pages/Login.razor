@page "/login"
@layout AuthLayout
@using Microsoft.AspNetCore.Components.Web
@inject FinanceTracker.Web.Services.ApiClient Api
@inject NavigationManager Nav

<PageTitle>Login — FinTracker</PageTitle>

<div class="auth-container">
    <div class="auth-card">
        <div class="logo">💰 FinTracker</div>
        <h2>@(_isRegister ? "Create Account" : "Welcome back")</h2>

        @if (_isRegister)
        {
            <div class="form-group">
                <label>First Name</label>
                <input @bind="_firstName" placeholder="John" />
            </div>
            <div class="form-group">
                <label>Last Name</label>
                <input @bind="_lastName" placeholder="Doe" />
            </div>
            <div class="form-group">
                <label>Preferred Currency</label>
                <select @bind="_currency">
                    <option>USD</option><option>EUR</option><option>GBP</option>
                    <option>RON</option><option>JPY</option><option>CAD</option>
                </select>
            </div>
        }

        <div class="form-group">
            <label>Email</label>
            <input type="email" @bind="_email" placeholder="you@example.com" />
        </div>
        <div class="form-group">
            <label>Password</label>
            <input type="password" @bind="_password" placeholder="••••••••" />
        </div>

        @if (_error is not null)
        {
            <div class="error-block" role="alert" aria-live="polite">
                <ul>
                    @foreach (var line in SplitErrorLines(_error))
                    {
                        <li>@line</li>
                    }
                </ul>
            </div>
        }

        <button class="btn-submit" @onclick="Submit" disabled="@_loading">
            @(_loading ? "Please wait..." : (_isRegister ? "Register" : "Login"))
        </button>

        <p class="toggle">
            @if (_isRegister)
            {
                <span>Already have an account?
                    <a href="javascript:void(0)" @onclick="() => { _isRegister = false; _error = null; }">Login</a>
                </span>
            }
            else
            {
                <span>No account?
                    <a href="javascript:void(0)" @onclick="() => { _isRegister = true; _error = null; }">Register</a>
                </span>
            }
        </p>
    </div>
</div>

@code {
    private string _email = "", _password = "", _firstName = "", _lastName = "", _currency = "USD";
    private string? _error;
    private bool _loading, _isRegister;

    private async Task Submit()
    {
        _error = null;
        _loading = true;

        if (_isRegister)
        {
            var (result, error) = await Api.RegisterAsync(new FinanceTracker.Contracts.RegisterDto(
                _firstName, _lastName, _email, _password, _currency));
            if (result is not null)
                Nav.NavigateTo("/");
            else
                _error = error ?? "Registration failed. Email may already be in use.";
        }
        else
        {
            var (result, error) = await Api.LoginAsync(new FinanceTracker.Contracts.LoginDto(_email, _password));
            if (result is not null)
                Nav.NavigateTo("/");
            else
                _error = error ?? "Invalid email or password.";
        }

        _loading = false;
    }

    private static IEnumerable<string> SplitErrorLines(string? error)
    {
        if (string.IsNullOrWhiteSpace(error))
            return Array.Empty<string>();

        return error
            .Split(';', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries)
            .Where(s => !string.IsNullOrWhiteSpace(s));
    }
}
