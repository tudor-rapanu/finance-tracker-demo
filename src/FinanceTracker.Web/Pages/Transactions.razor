@page "/transactions"
@using Microsoft.AspNetCore.Components.Web
@inject FinanceTracker.Web.Services.ApiClient Api
@inject IJSRuntime JS
@inject NavigationManager Nav
@inject ToastService ToastService
@inject PeriodStateService PeriodState

<PageTitle>Transactions — FinTracker</PageTitle>

<div class="transactions-page">
    <div class="page-header">
        <h1>Transactions</h1>
        <button class="btn-primary" @onclick="ToggleCreateForm">
            @(_showForm && !_editingTransactionId.HasValue ? "✕ Cancel" : "+ Add Transaction")
        </button>
    </div>

    @if (_showForm && !_editingTransactionId.HasValue)
    {
        <div class="form-card">
            <h2>New Transaction</h2>
            <div class="form-grid">
                <label>
                    Type
                    <select @onchange="OnTypeChanged">
                        <option value="1" selected="@(_form.Type == 1)">Income</option>
                        <option value="2" selected="@(_form.Type == 2)">Expense</option>
                    </select>
                </label>
                <label>
                    Amount
                    <input type="number" step="0.01" @bind="_form.Amount" />
                </label>
                <label>
                    Currency
                    <select @bind="_form.Currency">
                        <option>USD</option><option>EUR</option><option>GBP</option>
                        <option>RON</option><option>JPY</option><option>CAD</option>
                    </select>
                </label>
                <label>
                    Category
                    <select @bind="_form.Category">
                        @if (_form.Type == 1)
                        {
                            <option value="1">Salary</option>
                            <option value="2">Freelance</option>
                            <option value="3">Investment</option>
                            <option value="4">Gift</option>
                            <option value="5">Other Income</option>
                        }
                        else
                        {
                            <option value="10">Housing</option>
                            <option value="11">Food</option>
                            <option value="12">Transport</option>
                            <option value="13">Healthcare</option>
                            <option value="14">Entertainment</option>
                            <option value="15">Shopping</option>
                            <option value="16">Utilities</option>
                            <option value="17">Education</option>
                            <option value="18">Travel</option>
                            <option value="19">Other Expense</option>
                        }
                    </select>
                </label>
                <label>
                    Description
                    <input type="text" @bind="_form.Description" placeholder="e.g. Monthly salary" />
                </label>
                <label>
                    Date
                    <input type="date" @bind="_form.Date" />
                </label>
                <label style="grid-column: span 2">
                    Notes (optional)
                    <input type="text" @bind="_form.Notes" />
                </label>
            </div>
            @if (_formError is not null)
            {
                  <div class="error-block" role="alert" aria-live="polite">
                      <ul>
                          @foreach (var line in SplitErrorLines(_formError))
                          {
                              <li>@line</li>
                          }
                      </ul>
                  </div>
            }
            <button class="btn-primary" @onclick="SubmitTransaction" disabled="@_submitting">
                @(_submitting ? "Saving..." : "Save Transaction")
            </button>
        </div>
    }

    @if (_exportDropdownOpen)
    {
        <div class="dropdown-backdrop" @onclick="CloseExportDropdown"></div>
    }
    <div class="toolbar u-tablet-wrap u-phone-stack">
        <div class="filter-bar">
            <select @bind="_filterMonth">
                <option value="0">All months</option>
                @for (int m = 1; m <= 12; m++)
                {
                    <option value="@m">@(new DateTime(2000, m, 1).ToString("MMMM"))</option>
                }
            </select>
            <select @bind="_filterYear">
                @for (int y = DateTime.Now.Year; y >= DateTime.Now.Year - 3; y--)
                {
                    <option value="@y">@y</option>
                }
            </select>
            <button @onclick="LoadTransactions">Filter</button>
        </div>
        <div class="dropdown-anchor">
            <button class="btn-export" @onclick="ToggleExportDropdown" disabled="@_exportBusy"
                    aria-haspopup="menu" aria-expanded="@_exportDropdownOpen.ToString().ToLower()">
                @(_exportBusy ? "Processing…" : "Export ▾")
            </button>
            @if (_exportDropdownOpen)
            {
                <div class="export-dropdown" role="menu">
                    <button role="menuitem" @onclick='() => OpenExportModal("csv")'>Export as CSV</button>
                    <button role="menuitem" @onclick='() => OpenExportModal("pdf")'>Export as PDF</button>
                </div>
            }
        </div>
    </div>

    @if (!string.IsNullOrWhiteSpace(_exportStatusMessage))
    {
        <p class="export-status @(_exportHasError ? "export-error" : "")">@_exportStatusMessage</p>
    }

    @if (_loading)
    {
        <p>Loading...</p>
    }
    else if (_transactions.Any())
    {
        <div class="table-wrap">
            <table>
                <thead>
                    <tr>
                        <th>Date</th><th>Description</th><th>Category</th>
                        <th>Type</th><th>Amount</th><th>Base (@_preferredCurrency)</th><th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var t in _transactions)
                    {
                        <tr class="@(_editingTransactionId == t.Id ? "editing-row" : string.Empty)">
                            <td>@t.Date.ToShortDateString()</td>
                            <td>@t.Description</td>
                            <td>@((TransactionCategory)t.Category)</td>
                            <td><span class="badge @(t.Type == 1 ? "income" : "expense")">@(t.Type == 1 ? "Income" : "Expense")</span></td>
                            <td>@t.Amount.ToString("N2") @t.Currency</td>
                            <td>@t.AmountInBaseCurrency.ToString("N2") @_preferredCurrency</td>
                            <td>
                                <div class="row-actions">
                                    <button class="btn-edit" @onclick="() => StartEditTransaction(t)" title="Edit transaction">Edit</button>
                                    <button class="btn-delete" @onclick="() => ConfirmDeleteTransaction(t.Id)" title="Delete transaction">✕</button>
                                </div>
                            </td>
                        </tr>

                        @if (_editingTransactionId == t.Id)
                        {
                            <tr id="transaction-edit-row" class="edit-form-row">
                                <td colspan="7">
                                    <div class="edit-row-panel">
                                        <h2>Edit Transaction</h2>
                                        <div class="form-grid">
                                            <label>
                                                Type
                                                <select @onchange="OnTypeChanged">
                                                    <option value="1" selected="@(_form.Type == 1)">Income</option>
                                                    <option value="2" selected="@(_form.Type == 2)">Expense</option>
                                                </select>
                                            </label>
                                            <label>
                                                Amount
                                                <input type="number" step="0.01" @bind="_form.Amount" />
                                            </label>
                                            <label>
                                                Currency
                                                <select @bind="_form.Currency">
                                                    <option>USD</option><option>EUR</option><option>GBP</option>
                                                    <option>RON</option><option>JPY</option><option>CAD</option>
                                                </select>
                                            </label>
                                            <label>
                                                Category
                                                <select @bind="_form.Category">
                                                    @if (_form.Type == 1)
                                                    {
                                                        <option value="1">Salary</option>
                                                        <option value="2">Freelance</option>
                                                        <option value="3">Investment</option>
                                                        <option value="4">Gift</option>
                                                        <option value="5">Other Income</option>
                                                    }
                                                    else
                                                    {
                                                        <option value="10">Housing</option>
                                                        <option value="11">Food</option>
                                                        <option value="12">Transport</option>
                                                        <option value="13">Healthcare</option>
                                                        <option value="14">Entertainment</option>
                                                        <option value="15">Shopping</option>
                                                        <option value="16">Utilities</option>
                                                        <option value="17">Education</option>
                                                        <option value="18">Travel</option>
                                                        <option value="19">Other Expense</option>
                                                    }
                                                </select>
                                            </label>
                                            <label>
                                                Description
                                                <input type="text" @bind="_form.Description" placeholder="e.g. Monthly salary" />
                                            </label>
                                            <label>
                                                Date
                                                <input type="date" @bind="_form.Date" />
                                            </label>
                                            <label style="grid-column: span 2">
                                                Notes (optional)
                                                <input type="text" @bind="_form.Notes" />
                                            </label>
                                        </div>
                                        @if (_formError is not null)
                                        {
                                            <div class="error-block" role="alert" aria-live="polite">
                                                <ul>
                                                    @foreach (var line in SplitErrorLines(_formError))
                                                    {
                                                        <li>@line</li>
                                                    }
                                                </ul>
                                            </div>
                                        }
                                        <div class="edit-actions">
                                            <button class="btn-primary" @onclick="SubmitTransaction" disabled="@_submitting">
                                                @(_submitting ? "Saving..." : "Update Transaction")
                                            </button>
                                            <button class="btn-secondary" @onclick="CancelEditTransaction" disabled="@_submitting">Cancel</button>
                                        </div>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <div class="empty-state">
            <p>No transactions found. Add your first one above!</p>
        </div>
    }
</div>

@if (_exportModalOpen)
{
    <div class="modal-overlay" @onclick="CloseExportModal" role="dialog" aria-modal="true" aria-labelledby="export-modal-title">
        <div class="modal-card" @onclick:stopPropagation="true">
            <div class="modal-header">
                <h3 id="export-modal-title">Export as @(_exportFormat.ToUpperInvariant())</h3>
                <button class="modal-close-btn" @onclick="CloseExportModal" aria-label="Close export dialog">✕</button>
            </div>
            <div class="modal-body">
                <div class="period-options">
                    <label class="radio-option @(_exportRangeMode == "thismonth" ? "radio-option--selected" : "")">
                        <input type="radio" name="exportPeriod" checked="@(_exportRangeMode == "thismonth")"
                               @onchange='() => _exportRangeMode = "thismonth"' />
                        <span class="radio-label-text">This month</span>
                        <span class="period-hint">@CurrentFilterMonthLabel</span>
                    </label>
                    <label class="radio-option @(_exportRangeMode == "thisyear" ? "radio-option--selected" : "")">
                        <input type="radio" name="exportPeriod" checked="@(_exportRangeMode == "thisyear")"
                               @onchange='() => _exportRangeMode = "thisyear"' />
                        <span class="radio-label-text">This year</span>
                        <span class="period-hint">@_filterYear</span>
                    </label>
                    <label class="radio-option @(_exportRangeMode == "custom" ? "radio-option--selected" : "")">
                        <input type="radio" name="exportPeriod" checked="@(_exportRangeMode == "custom")"
                               @onchange='() => _exportRangeMode = "custom"' />
                        <span class="radio-label-text">Custom period</span>
                    </label>
                </div>
                @if (_exportRangeMode == "custom")
                {
                    <div class="custom-period-pickers">
                        <div class="picker-row">
                            <span class="picker-label">From</span>
                            <select @bind="_exportFromMonth" aria-label="From month">
                                @for (int m = 1; m <= 12; m++)
                                {
                                    <option value="@m">@(new DateTime(2000, m, 1).ToString("MMMM"))</option>
                                }
                            </select>
                            <select @bind="_exportFromYear" aria-label="From year">
                                @for (int y = DateTime.Now.Year; y >= DateTime.Now.Year - 5; y--)
                                {
                                    <option value="@y">@y</option>
                                }
                            </select>
                        </div>
                        <div class="picker-row">
                            <span class="picker-label">To</span>
                            <select @bind="_exportToMonth" aria-label="To month">
                                @for (int m = 1; m <= 12; m++)
                                {
                                    <option value="@m">@(new DateTime(2000, m, 1).ToString("MMMM"))</option>
                                }
                            </select>
                            <select @bind="_exportToYear" aria-label="To year">
                                @for (int y = DateTime.Now.Year; y >= DateTime.Now.Year - 5; y--)
                                {
                                    <option value="@y">@y</option>
                                }
                            </select>
                        </div>
                    </div>
                }
            </div>
            @if (_exportModalError is not null)
            {
                <div class="modal-error" role="alert">@_exportModalError</div>
            }
            <div class="modal-footer">
                <button class="btn-secondary" @onclick="CloseExportModal">Cancel</button>
                <button class="btn-primary" @onclick="ExportTransactionsAsync">Download</button>
            </div>
        </div>
    </div>
}

<ConfirmDialog @ref="_confirmDialog" />

@code {
    private List<FinanceTracker.Contracts.TransactionDto> _transactions = new();
    private bool _loading = true;
    private bool _showForm = false;
    private bool _submitting = false;
    private string? _formError;
    private ConfirmDialog? _confirmDialog;
    private Guid? _editingTransactionId;
    private bool _scrollToEditPanel;
    private int _filterMonth = DateTime.Now.Month;
    private int _filterYear = DateTime.Now.Year;
    private string _preferredCurrency = "USD";
    private bool _exportBusy;
    private bool _exportDropdownOpen;
    private bool _exportModalOpen;
    private bool _exportHasError;
    private string? _exportModalError;
    private string _exportFormat = "csv";
    private string _exportRangeMode = "thismonth";
    private int _exportFromMonth = 1;
    private int _exportFromYear = DateTime.Now.Year;
    private int _exportToMonth = DateTime.Now.Month;
    private int _exportToYear = DateTime.Now.Year;
    private string? _exportStatusMessage;

    private string CurrentFilterMonthLabel =>
        _filterMonth > 0
            ? new DateTime(_filterYear, _filterMonth, 1).ToString("MMMM yyyy")
            : $"All of {_filterYear}";

    private void ToggleExportDropdown() => _exportDropdownOpen = !_exportDropdownOpen;
    private void CloseExportDropdown() => _exportDropdownOpen = false;

    private void OpenExportModal(string format)
    {
        _exportFormat = format;
        _exportDropdownOpen = false;
        _exportModalOpen = true;
        _exportStatusMessage = null;
        _exportHasError = false;
        _exportModalError = null;
    }

    private void CloseExportModal() => _exportModalOpen = false;

    private FormModel _form = new();

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        await JS.InvokeVoidAsync("finTracker.updateTableScrollHints");

        if (!_scrollToEditPanel)
            return;

        _scrollToEditPanel = false;
        await JS.InvokeAsync<object?>("finTracker.scrollIntoView", "#transaction-edit-row");
    }

    protected override async Task OnInitializedAsync()
    {
        if (!await Api.IsAuthenticatedAsync()) { Nav.NavigateTo("/login"); return; }
        _preferredCurrency = await Api.GetPreferredCurrencyAsync() ?? "USD";
        await PeriodState.EnsureLoadedAsync();
        _filterMonth = PeriodState.Month;
        _filterYear = PeriodState.Year;
        ResetCreateForm();
        await LoadTransactions();
    }

    private async Task LoadTransactions()
    {
        _loading = true;
        await PeriodState.SetAsync(_filterMonth > 0 ? _filterMonth : null, _filterYear);
        _transactions = await Api.GetTransactionsAsync(
            _filterMonth > 0 ? _filterMonth : null,
            _filterYear);
        _loading = false;
    }

    private async Task ExportTransactionsAsync()
    {
        _exportModalError = null;
        _exportHasError = false;

        // Resolve the effective from/to for the selected mode
        int fromMonth, fromYear, toMonth, toYear;
        if (_exportRangeMode == "thismonth")
        {
            fromMonth = toMonth = _filterMonth > 0 ? _filterMonth : DateTime.Now.Month;
            fromYear  = toYear  = _filterYear;
        }
        else if (_exportRangeMode == "thisyear")
        {
            fromMonth = 1; fromYear = _filterYear;
            toMonth   = 12; toYear  = _filterYear;
        }
        else // custom
        {
            fromMonth = _exportFromMonth; fromYear = _exportFromYear;
            toMonth   = _exportToMonth;   toYear   = _exportToYear;
        }

        // Validate — keep modal open and show error inside it
        var from = new DateTime(fromYear, fromMonth, 1);
        var to   = new DateTime(toYear,   toMonth,   1);
        if (from > to)
        {
            _exportModalError = "'From' must be before or equal to 'To'.";
            return;
        }

        // Validation passed — close modal and begin export
        _exportModalOpen = false;

        bool isSingleMonth = from == to;

        if (isSingleMonth)
        {
            _exportBusy = true;
            _exportStatusMessage = "Generating export…";
            StateHasChanged();

            var result = await Api.ExportTransactionsMonthAsync(_exportFormat, fromMonth, fromYear);
            _exportBusy = false;

            if (!result.Success || result.Data is null)
            {
                _exportHasError = true;
                _exportStatusMessage = result.Error ?? "Export failed.";
                return;
            }

            await DownloadFileAsync(result.Data);
            _exportStatusMessage = "Export downloaded.";
            ToastService.Show("Transaction export downloaded.");
            return;
        }

        // Multi-month: queue background job
        _exportBusy = true;
        _exportStatusMessage = "Queuing export job…";
        StateHasChanged();

        var request = new FinanceTracker.Contracts.TransactionExportRequestDto(
            _exportFormat,
            null, null,
            fromMonth, fromYear,
            toMonth,   toYear);

        var queueResult = await Api.QueueTransactionExportJobAsync(request);
        if (!queueResult.Success || queueResult.Data is null)
        {
            _exportBusy = false;
            _exportHasError = true;
            _exportStatusMessage = queueResult.Error ?? "Could not queue export job.";
            return;
        }

        await PollExportJobAsync(queueResult.Data.JobId);
    }

    private async Task PollExportJobAsync(Guid jobId)
    {
        const int maxAttempts = 120;

        for (var attempt = 0; attempt < maxAttempts; attempt++)
        {
            var statusResult = await Api.GetTransactionExportJobStatusAsync(jobId);
            if (!statusResult.Success || statusResult.Data is null)
            {
                _exportBusy = false;
                _exportHasError = true;
                _exportStatusMessage = statusResult.Error ?? "Could not retrieve export status.";
                return;
            }

            var status = statusResult.Data;
            _exportStatusMessage = $"{status.Status} — {status.Progress}%";
            StateHasChanged();

            if (status.Status.Equals("Completed", StringComparison.OrdinalIgnoreCase) && status.ReadyForDownload)
            {
                var fileResult = await Api.DownloadTransactionExportJobAsync(jobId, _exportFormat);
                _exportBusy = false;

                if (!fileResult.Success || fileResult.Data is null)
                {
                    _exportHasError = true;
                    _exportStatusMessage = fileResult.Error ?? "Export finished, but download failed.";
                    return;
                }

                await DownloadFileAsync(fileResult.Data);
                _exportStatusMessage = "Export downloaded.";
                ToastService.Show("Background export completed and downloaded.");
                return;
            }

            if (status.Status.Equals("Failed", StringComparison.OrdinalIgnoreCase))
            {
                _exportBusy = false;
                _exportHasError = true;
                _exportStatusMessage = status.Error ?? "Export job failed.";
                return;
            }

            await Task.Delay(2000);
        }

        _exportBusy = false;
        _exportHasError = true;
        _exportStatusMessage = "Export is still running. Try again in a moment.";
    }
    private async Task ConfirmDeleteTransaction(Guid id)
    {
        var confirmed = await _confirmDialog!.ShowAsync(
            title: "Delete transaction",
            message: "Are you sure you want to delete this transaction?",
            danger: true);
        if (!confirmed) return;
        await Api.DeleteTransactionAsync(id);
        await LoadTransactions();
        ToastService.Show("Transaction deleted.", ToastType.Info);
    }

    private Task OnTypeChanged(ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out int type))
        {
            _form.Type = type;
            _form.Category = type == 1 ? 1 : 10;
        }
        return Task.CompletedTask;
    }

    private async Task SubmitTransaction()
    {
        _formError = null;
        if (_form.Amount <= 0) { _formError = "Amount must be greater than 0."; return; }
        if (string.IsNullOrWhiteSpace(_form.Description)) { _formError = "Description is required."; return; }
        var isEditing = _editingTransactionId.HasValue;

        _submitting = true;
        var result = _editingTransactionId.HasValue
            ? await Api.UpdateTransactionAsync(_editingTransactionId.Value, new FinanceTracker.Contracts.UpdateTransactionDto(
                _form.Amount, _form.Currency, _form.Type, _form.Category, _form.Description, _form.Date, _form.Notes))
            : await Api.CreateTransactionAsync(new FinanceTracker.Contracts.CreateTransactionDto(
                _form.Amount, _form.Currency, _form.Type, _form.Category,
                _form.Description, _form.Date, _form.Notes));
        _submitting = false;

        if (result.Success)
        {
            _showForm = false;
            _editingTransactionId = null;
            ResetCreateForm();
            await LoadTransactions();
            ToastService.Show(isEditing ? "Transaction updated." : "Transaction saved.");
        }
        else
        {
            _formError = result.Error ?? "Failed to save transaction. Please try again.";
        }
    }

    private void ToggleCreateForm()
    {
        if (_editingTransactionId.HasValue)
        {
            _editingTransactionId = null;
            _showForm = true;
            _formError = null;
            ResetCreateForm();
            return;
        }

        _showForm = !_showForm;
        if (!_showForm)
        {
            _formError = null;
            ResetCreateForm();
        }
    }

    private void StartEditTransaction(FinanceTracker.Contracts.TransactionDto transaction)
    {
        if (_editingTransactionId == transaction.Id)
        {
            CancelEditTransaction();
            return;
        }

        _editingTransactionId = transaction.Id;
        _scrollToEditPanel = true;
        _showForm = false;
        _formError = null;

        _form = new FormModel
        {
            Type = transaction.Type,
            Amount = transaction.Amount,
            Currency = transaction.Currency,
            Category = transaction.Category,
            Description = transaction.Description,
            Date = transaction.Date,
            Notes = transaction.Notes
        };
    }

    private void CancelEditTransaction()
    {
        _editingTransactionId = null;
        _formError = null;
        ResetCreateForm();
    }

    private void ResetCreateForm()
    {
        _form = new FormModel
        {
            Currency = _preferredCurrency,
            Date = GetDefaultTransactionDate()
        };
    }

    private DateTime GetDefaultTransactionDate()
    {
        if (_filterMonth <= 0)
            return DateTime.Today;

        var selectedPeriod = new DateTime(_filterYear, _filterMonth, 1);
        var currentPeriod  = new DateTime(DateTime.Today.Year, DateTime.Today.Month, 1);

        if (selectedPeriod < currentPeriod)
            return selectedPeriod.AddMonths(1).AddDays(-1);

        if (selectedPeriod > currentPeriod)
            return selectedPeriod;

        return DateTime.Today;
    }

    private async Task DownloadFileAsync(ApiClient.DownloadedFile file)
    {
        var base64 = Convert.ToBase64String(file.Bytes);
        await JS.InvokeAsync<object?>("finTracker.downloadBase64File", file.FileName, file.ContentType, base64);
    }

      private static IEnumerable<string> SplitErrorLines(string? error)
      {
          if (string.IsNullOrWhiteSpace(error))
              return Array.Empty<string>();

          return error
              .Split(';', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries)
              .Where(s => !string.IsNullOrWhiteSpace(s));
      }

    private enum TransactionCategory
    {
        Salary=1,Freelance,Investment,Gift,OtherIncome,
        Housing=10,Food,Transport,Healthcare,Entertainment,Shopping,Utilities,Education,Travel,OtherExpense
    }

    private class FormModel
    {
        public int Type { get; set; } = 2;
        public decimal Amount { get; set; }
        public string Currency { get; set; } = "USD";
        public int Category { get; set; } = 11;
        public string Description { get; set; } = "";
        public DateTime Date { get; set; } = DateTime.Today;
        public string? Notes { get; set; }
    }
}
